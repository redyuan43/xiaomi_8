#!/bin/busybox sh

export PATH=/sbin:/bin:/usr/sbin:/usr/bin
mount -t devtmpfs devtmpfs /dev 2>/dev/null || true
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t tmpfs tmpfs /run
echo "equuleus: Linux test initramfs started" > /dev/kmsg

# Wait for the USB gadget before configuring the diagnostic network.
attempt=0
while ! ip link show usb0 >/dev/null 2>&1 && [ "$attempt" -lt 20 ]; do
    sleep 1
    attempt=$((attempt + 1))
done
ip link set usb0 up 2>/dev/null || true
ip addr add 192.168.7.2/24 dev usb0 2>/dev/null || true
nc -lk -p 2323 -e /bin/sh &

# This initramfs must remain non-destructive during hardware bring-up.
exec /bin/sh

