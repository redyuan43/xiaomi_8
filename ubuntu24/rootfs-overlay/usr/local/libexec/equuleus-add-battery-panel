#!/bin/sh
set -eu

channel=xfce4-panel
panel=/panels/panel-1/plugin-ids

panel_pid=$(pgrep -n -x xfce4-panel || true)
[ -n "$panel_pid" ] || exit 0
session_env="/proc/$panel_pid/environ"
DBUS_SESSION_BUS_ADDRESS=$(tr '\0' '\n' < "$session_env" |
    sed -n 's/^DBUS_SESSION_BUS_ADDRESS=//p' | head -n 1)
[ -n "$DBUS_SESSION_BUS_ADDRESS" ] || exit 0
export DBUS_SESSION_BUS_ADDRESS

config_dir="$HOME/.config/xfce4/panel"
template=/usr/local/share/equuleus/battery-genmon.rc

ids=$(xfconf-query -c "$channel" -p "$panel" |
    awk '/^[0-9]+$/ { print }')
[ -n "$ids" ] || exit 0

plugin_id=9
plugin=$(xfconf-query -c "$channel" -p "/plugins/plugin-$plugin_id" \
    2>/dev/null || true)
case "$plugin" in
    ''|battery|genmon) ;;
    *)
        plugin_id=23
        while xfconf-query -c "$channel" -p "/plugins/plugin-$plugin_id" \
            >/dev/null 2>&1; do
            plugin_id=$((plugin_id + 1))
        done
        ;;
esac

install -d -m 0755 "$config_dir"
install -m 0644 "$template" "$config_dir/genmon-$plugin_id.rc"

if xfconf-query -c "$channel" -p "/plugins/plugin-$plugin_id" \
    >/dev/null 2>&1; then
    xfconf-query -c "$channel" -p "/plugins/plugin-$plugin_id" -s genmon
else
    xfconf-query -c "$channel" -p "/plugins/plugin-$plugin_id" -n \
        -t string -s genmon
fi

set --
plugin_present=0
for id in $ids; do
    plugin=$(xfconf-query -c "$channel" -p "/plugins/plugin-$id" \
        2>/dev/null || true)
    if [ "$id" != "$plugin_id" ]; then
        case "$plugin" in
            battery|genmon) continue ;;
        esac
    fi
    if [ "$plugin_present" -eq 0 ] && [ "$plugin" = notification-plugin ]; then
        set -- "$@" -t int -s "$plugin_id"
        plugin_present=1
    fi
    set -- "$@" -t int -s "$id"
    [ "$id" != "$plugin_id" ] || plugin_present=1
done
[ "$plugin_present" -eq 1 ] ||
    set -- "$@" -t int -s "$plugin_id"
xfconf-query -c "$channel" -p "$panel" -a "$@"
