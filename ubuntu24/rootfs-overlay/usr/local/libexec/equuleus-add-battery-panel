#!/bin/sh
set -eu

channel=xfce4-panel
panel=/panels/panel-1/plugin-ids
plugin_id=9

panel_pid=$(pgrep -n -x xfce4-panel || true)
[ -n "$panel_pid" ] || exit 0
session_env="/proc/$panel_pid/environ"
DBUS_SESSION_BUS_ADDRESS=$(tr '\0' '\n' < "$session_env" |
    sed -n 's/^DBUS_SESSION_BUS_ADDRESS=//p' | head -n 1)
[ -n "$DBUS_SESSION_BUS_ADDRESS" ] || exit 0
export DBUS_SESSION_BUS_ADDRESS

config_dir="$HOME/.config/xfce4/panel"
template=/usr/local/share/equuleus/battery-panel.rc

while plugin=$(xfconf-query -c "$channel" -p "/plugins/plugin-$plugin_id" \
    2>/dev/null); do
    if [ "$plugin" = battery ]; then
        install -d -m 0755 "$config_dir"
        install -m 0644 "$template" "$config_dir/battery-$plugin_id.rc"
        exit 0
    fi
    plugin_id=$((plugin_id + 1))
done

ids=$(xfconf-query -c "$channel" -p "$panel" |
    awk '/^[0-9]+$/ { print }')
[ -n "$ids" ] || exit 0

xfconf-query -c "$channel" -p "/plugins/plugin-$plugin_id" \
    -n -t string -s battery
install -d -m 0755 "$config_dir"
install -m 0644 "$template" "$config_dir/battery-$plugin_id.rc"

set --
for id in $ids; do
    set -- "$@" -t int -s "$id"
done
xfconf-query -c "$channel" -p "$panel" -a "$@" -t int -s "$plugin_id"
