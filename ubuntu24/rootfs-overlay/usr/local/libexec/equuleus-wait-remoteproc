#!/bin/sh
set -eu

expected_name=${1:-}

for _ in $(seq 1 60); do
    for state in /sys/class/remoteproc/remoteproc*/state; do
        [ -r "$state" ] || continue
        remoteproc=${state%/state}
        if [ -n "$expected_name" ] &&
           [ "$(cat "$remoteproc/name")" != "$expected_name" ]; then
            continue
        fi
        case "$(cat "$state")" in
            running)
                exit 0
                ;;
            offline)
                printf start > "$state"
                ;;
        esac
    done
    sleep 1
done
echo "Remote processor ${expected_name:-device} did not reach running state" >&2
exit 1
