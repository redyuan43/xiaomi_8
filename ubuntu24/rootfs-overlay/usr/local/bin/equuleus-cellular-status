#!/bin/sh
set -u

device=${1:-qrtr://0}

section()
{
	printf '\n== %s ==\n' "$1"
}

run_qmi()
{
	section "$1"
	shift
	timeout 15 qmicli -d "$device" "$@" 2>&1 || true
}

section "MSS remote processor"
for remoteproc in /sys/class/remoteproc/remoteproc*; do
	[ -r "$remoteproc/name" ] || continue
	name=$(cat "$remoteproc/name")
	[ "$name" = "4080000.remoteproc" ] || continue
	printf 'name: %s\nstate: ' "$name"
	cat "$remoteproc/state"
done

section "QRTR modem services"
timeout 5 qrtr-lookup 2>&1 |
	awk 'NR == 1 || $1 == 1 || $1 == 2 || $1 == 3 || $1 == 11 || $1 == 49'

run_qmi "Operating mode" --dms-get-operating-mode
run_qmi "SIM slots" --uim-get-slot-status
run_qmi "SIM card" --uim-get-card-status
run_qmi "Registration" --nas-get-serving-system
run_qmi "Signal" --nas-get-signal-strength

section "Cellular network interfaces"
ip -details link show |
	awk '/^[0-9]+: (rmnet|wwan|ipa)/ { show=1 }
	     /^[0-9]+:/ && $2 !~ /^(rmnet|wwan|ipa)/ { show=0 }
	     show'

section "ModemManager"
timeout 10 mmcli -L 2>&1 || true
