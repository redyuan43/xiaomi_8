#!/bin/sh
unset SESSION_MANAGER
unset DBUS_SESSION_BUS_ADDRESS
export LIBGL_ALWAYS_SOFTWARE=1
export WEBKIT_DISABLE_COMPOSITING_MODE=1
# The downstream 5.12 kernel rejects unprivileged user namespaces even though
# CONFIG_USER_NS is enabled, so WebKit's bubblewrap sandbox cannot initialize.
# Remove this compatibility setting when the kernel is upgraded.
export WEBKIT_DISABLE_SANDBOX_THIS_IS_DANGEROUS=1
exec dbus-run-session sh -c '
if command -v gnome-keyring-daemon >/dev/null 2>&1; then
    eval "$(gnome-keyring-daemon --start --components=secrets)"
    export GNOME_KEYRING_CONTROL
fi
exec startxfce4
'
